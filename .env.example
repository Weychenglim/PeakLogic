# Backend-only environment for FastAPI (`api.py`).
# Copy this file to `.env` in the repository root for local development.
# Do not commit `.env`.

# Optional dashboard assistant provider.
# Leave these unset to use grounded dashboard-data fallback mode.
AI_ASSISTANT_API_KEY="YOUR_PROVIDER_KEY"
AI_ASSISTANT_BASE_URL="https://api.z.ai/api/coding/paas/v4/chat/completions"
AI_ASSISTANT_MODEL="glm-5.1"

# Frontend origins allowed by FastAPI CORS in addition to local defaults.
# FRONTEND_ORIGINS="https://your-vercel-app.vercel.app"
