# Frontend-only Vite environment.
# Do not put assistant/API provider secrets in this file.

# FastAPI backend URL. For local development, use http://localhost:8000.
# For Vercel, set this to the deployed Render URL, for example:
# https://peaklogic-api.onrender.com
VITE_API_BASE_URL="http://localhost:8000"

# Supabase credentials (frontend)
# Leave unset if the public demo should run without login/cache.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
